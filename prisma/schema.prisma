generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  email     String   @unique
  name      String?
  user_name String?  @db.VarChar
  password  String?  @db.VarChar
}

model vehicle {
  id          BigInt   @id @default(autoincrement())
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  code        String?  @unique(map: "Vehicle_code_key") @default(dbgenerated("lpad((floor((random() * (1000000)::double precision)))::text, 6, '0'::text)")) @db.VarChar
  fname       String?  @db.VarChar
  lname       String?  @db.VarChar
  rego_number String?  @db.VarChar
  car_year    Int?
  car_make    String?  @db.VarChar
  car_model   String?  @db.VarChar
  status      status?  @default(Gone)
  location    String?
}

enum status {
  Gone
  Parked
  Requested
}
